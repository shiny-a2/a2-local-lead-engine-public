# A2 Local Lead Engine - safe operator setup template
# Copy to .env and fill only the values Amirali controls manually.
# Keep every live/external/send flag false until dry-run stop points pass.

APP_ENV=development
APP_NAME=A2 Local Lead Engine
APP_TIMEZONE=Pacific/Auckland
PUBLIC_BASE_URL=https://amiraliyaghouti.com
UNSUBSCRIBE_BASE_URL=https://amiraliyaghouti.com/unsubscribe

# Required before DB-backed dry-runs.
DATABASE_URL=

LOG_LEVEL=INFO
AUDIT_LOG_ENABLED=true
LOCAL_API_ONLY=true

# Global safety: keep blocked for operator setup and controlled dry-run planning.
GLOBAL_OUTREACH_KILL_SWITCH=true
LIVE_API_CALLS_ENABLED=false
LEAD_COLLECTION_ENABLED=false
AI_GENERATION_ENABLED=false
EMAIL_DRAFTING_ENABLED=false
EMAIL_JUDGE_ENABLED=false
EMAIL_AI_JUDGE_ENABLED=false
EMAIL_SENDING_ENABLED=false
CONTROLLED_SEND_ENABLED=false
PROVIDER_SEND_ENABLED=false
FOLLOWUP_ENABLED=false
VOICE_CALLS_ENABLED=false
GOOGLE_MAPS_ENABLED=false
PUBLIC_DASHBOARD_ENABLED=false
INBOX_SYNC_ENABLED=false
IMAP_SYNC_ENABLED=false
PROVIDER_WEBHOOK_EVENTS_ENABLED=false

# Dashboard auth: required before hosted dashboard use.
PHASE9_REVIEW_DASHBOARD_ENABLED=false
PHASE9_REVIEW_DASHBOARD_LOCAL_ONLY=true
PHASE9_BASIC_AUTH_ENABLED=true
PHASE9_REVIEW_USERNAME=
PHASE9_REVIEW_PASSWORD_HASH=
PHASE10_SEND_DASHBOARD_ENABLED=true
PHASE10_DASHBOARD_RTL=true
PHASE10_DASHBOARD_LANGUAGE=fa
PHASE11_DASHBOARD_RTL=true
PHASE11_DASHBOARD_LANGUAGE=fa
PHASE12_DASHBOARD_RTL=true
PHASE12_DASHBOARD_LANGUAGE=fa
PHASE13_DASHBOARD_RTL=true
PHASE13_DASHBOARD_LANGUAGE=fa
PHASE14_GOVERNANCE_DASHBOARD_ENABLED=true
PHASE14_DASHBOARD_RTL=true
PHASE14_DASHBOARD_LANGUAGE=fa

# Source/API keys: keep empty until a live source/API phase is explicitly approved.
GEOAPIFY_API_KEY=
TAVILY_API_KEY=
NZBN_API_KEY=
OPENAI_API_KEY=
OPENAI_EMAIL_MODEL=
OPENAI_JUDGE_MODEL=
OPENAI_REPLY_CLASSIFIER_MODEL=

# Sender metadata: required later before live sending.
DEFAULT_SENDER_PROFILE_SLUG=amirali_domain_default
DEFAULT_FROM_EMAIL=
DEFAULT_FROM_NAME=Amirali Yaghouti
DEFAULT_REPLY_TO_EMAIL=
EMAIL_PROVIDER=cpanel_smtp
EMAIL_PROVIDER_SLUG=amirali_cpanel_default
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true

# Unsubscribe: secret required before live send.
UNSUBSCRIBE_PUBLIC_BASE_URL=https://amiraliyaghouti.com/unsubscribe
UNSUBSCRIBE_TOKEN_SECRET=

# Send limits: conservative defaults; still blocked by flags above.
SEND_WARMUP_MODE=true
SEND_WARMUP_STAGE=starter
SEND_DAILY_LIMIT=10
SEND_PER_RUN_LIMIT=5
SEND_PER_DOMAIN_DAILY_LIMIT=1
SEND_COOLDOWN_DAYS=90
TARGET_TIMEZONE=Pacific/Auckland
SEND_WINDOW_ENABLED=true
SEND_WINDOW_START=09:00
SEND_WINDOW_END=16:30
SEND_ALLOWED_DAYS=Mon,Tue,Wed,Thu
SEND_WINDOW_OUTSIDE_POLICY=block

# Plain text/no tracking.
EMAIL_PLAIN_TEXT_ONLY=true
EMAIL_DISABLE_TRACKING_PIXEL=true
EMAIL_DISABLE_CLICK_TRACKING=true
EMAIL_DISABLE_ATTACHMENTS=true
EMAIL_DISABLE_HTML=true

# Inbox config: keep disabled until Phase 11 setup.
IMAP_HOST=
IMAP_PORT=993
IMAP_USERNAME=
IMAP_PASSWORD=
IMAP_USE_SSL=true
IMAP_MAILBOX=INBOX
IMAP_MARK_READ=false
IMAP_DELETE_MESSAGES=false
IMAP_MOVE_PROCESSED=false

# Human-only sales controls.
PHASE12_BLOCK_AUTOMATIC_RESPONSE_SEND=true
PHASE12_BLOCK_AUTOMATIC_MEETING_SCHEDULING=true
PHASE12_BLOCK_AUTOMATIC_PRICE_QUOTE=true
PHASE12_BLOCK_AUTOMATIC_PROPOSAL_SEND=true
PHASE12_BLOCK_AUTOMATIC_PAYMENT_LINK=true
PHASE13_BLOCK_AUTO_REPLY=true
PHASE13_BLOCK_AUTO_FOLLOWUP=true
PHASE13_BLOCK_AUTO_QUOTE=true
PHASE13_BLOCK_AUTO_MEETING=true
PHASE13_BLOCK_AUTO_PROPOSAL=true
PHASE13_BLOCK_PAYMENT_LINK=true
PHASE13_BLOCK_AUTO_CALL=true

# Phase 14/15 boundary.
PHASE14_MIN_SAMPLE_FOR_SCALE_DECISION=25
PHASE15_BOUNDARY_STATUS=POST_MVP_SCALE_NOT_REQUIRED_FOR_NZ_TINY_PILOT
